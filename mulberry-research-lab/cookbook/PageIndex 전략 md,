2.2 Mulberry와의 구체적 연동 방안
python
# mcp_server_pageindex.py (예시)
from pageindex import PageIndexEngine
from mcp.server import Server

engine = PageIndexEngine(model="gpt-4")  # 또는 DeepSeek
server = Server("pageindex-mcp")

@server.tool()
async def search_document(query: str, doc_path: str) -> str:
    """문서에서 질문에 가장 관련성 높은 구절을 찾아 반환"""
    result = engine.query(doc_path, query)
    return f"출처: {result['source']}\n답변: {result['answer']}"
이 MCP 서버를 우리의 게이트웨이에 등록하면, 모든 Mulberry 에이전트가 자연어로 문서 검색을 요청할 수 있습니다.

